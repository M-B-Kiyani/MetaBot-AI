# Production Environment Configuration
# Copy this file to .env.production and update with your production values

# Server Configuration
NODE_ENV=production
PORT=3000
API_BASE_URL=https://your-domain.com
REQUEST_TIMEOUT=30000

# Database
DATABASE_URL=postgresql://username:password@host:port/database
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_POOL_SIZE=20
DATABASE_QUERY_TIMEOUT=10000

# Authentication - SECURE PRODUCTION KEYS
API_KEY=your-secure-api-key-here
WIDGET_API_KEY=your-secure-widget-api-key-here
PUBLIC_WIDGET_KEY=your-public-widget-key-here
SESSION_SECRET=your-secure-session-secret-here
API_KEY_HEADER=Authorization

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,x-api-key
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Email Configuration
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=your-smtp-password
ADMIN_EMAIL=admin@your-domain.com
FROM_EMAIL=noreply@your-domain.com
FROM_NAME=Your Company AI Assistant
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY=2000

# Google Calendar (Optional)
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_CALENDAR_TIMEZONE=Europe/London
GOOGLE_CALENDAR_RETRY_ATTEMPTS=3
GOOGLE_CALENDAR_RETRY_DELAY=1000

# HubSpot CRM (Optional)
HUBSPOT_ENABLED=true
HUBSPOT_ACCESS_TOKEN=your-hubspot-access-token
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_PERSONAL_ACCESS_KEY=your-hubspot-personal-access-key
HUBSPOT_RETRY_ATTEMPTS=3
HUBSPOT_RETRY_DELAY=1000

# Retell AI Voice (Optional)
RETELL_ENABLED=true
RETELL_API_KEY=your-retell-api-key
RETELL_AGENT_ID=your-retell-agent-id
RETELL_LLM_ID=your-retell-llm-id
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret
RETELL_AGENT_WEBHOOK_URL=https://your-domain.com/api/retell/webhook
RETELL_CUSTOM_LLM_WEBSOCKET_URL=wss://your-domain.com/api/retell/llm

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Logging
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_MAX_FILE_SIZE=20m
LOG_MAX_FILES=14d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL=false

# Business Rules
BUSINESS_DAYS=1,2,3,4,5
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=17
BUSINESS_TIMEZONE=Europe/London
BUFFER_MINUTES=15
MIN_ADVANCE_HOURS=1
MAX_ADVANCE_HOURS=24
MAX_BOOKINGS_PER_EMAIL=100
FREQUENCY_WINDOW_DAYS=365