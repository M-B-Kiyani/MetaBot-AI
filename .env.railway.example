# Railway Environment Configuration for AI Booking Voice Assistant
# Copy this file and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://username:password@host:port/database
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_POOL_SIZE=20
DATABASE_QUERY_TIMEOUT=10000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=3000
API_BASE_URL=https://your-backend.railway.app
REQUEST_TIMEOUT=30000

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOWED_ORIGINS=https://your-frontend.railway.app,https://your-widget.railway.app
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,x-api-key
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# =============================================================================
# GOOGLE CALENDAR INTEGRATION
# =============================================================================
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"service-account@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/service-account%40your-project.iam.gserviceaccount.com"}
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com
GOOGLE_CALENDAR_TIMEZONE=Europe/London
GOOGLE_CALENDAR_RETRY_ATTEMPTS=3
GOOGLE_CALENDAR_RETRY_DELAY=1000

# =============================================================================
# HUBSPOT CRM INTEGRATION
# =============================================================================
HUBSPOT_ENABLED=true
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_RETRY_ATTEMPTS=3
HUBSPOT_RETRY_DELAY=1000

# =============================================================================
# RETELL AI VOICE INTEGRATION
# =============================================================================
RETELL_ENABLED=true
RETELL_API_KEY=your-retell-api-key
RETELL_AGENT_ID=your-retell-agent-id
RETELL_WEBHOOK_SECRET=your-webhook-secret
RETELL_AGENT_WEBHOOK_URL=https://your-backend.railway.app/api/voice/webhook

# =============================================================================
# GOOGLE GEMINI AI
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@yourcompany.com
FROM_EMAIL=noreply@yourcompany.com
FROM_NAME=AI Booking Assistant
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY=2000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_MAX_FILE_SIZE=20m
LOG_MAX_FILES=14d

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL=false

# =============================================================================
# BUSINESS RULES
# =============================================================================
BUSINESS_DAYS=1,2,3,4,5
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=17
BUSINESS_TIMEZONE=Europe/London
BUFFER_MINUTES=15
MIN_ADVANCE_HOURS=1
MAX_ADVANCE_HOURS=168
MAX_BOOKINGS_PER_EMAIL=100
FREQUENCY_WINDOW_DAYS=365

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
API_KEY=your-api-key-for-internal-services
WIDGET_API_KEY=your-widget-api-key
PUBLIC_WIDGET_KEY=your-public-widget-key
SESSION_SECRET=your-session-secret-for-jwt
API_KEY_HEADER=Authorization

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (for Vite)
# =============================================================================
# Add these to your frontend service in Railway:
# VITE_API_URL=https://your-backend.railway.app
# VITE_RETELL_AGENT_ID=your-retell-agent-id

# =============================================================================
# WIDGET ENVIRONMENT VARIABLES (for Vite)
# =============================================================================
# Add these to your widget service in Railway:
# VITE_API_URL=https://your-backend.railway.app